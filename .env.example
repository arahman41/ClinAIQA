# Copy this file to .env and fill in real values. Never commit .env.

# Claude API
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# PostgreSQL (used by both the app and Alembic)
DATABASE_URL=postgresql+asyncpg://clinaiqa:clinaiqa@localhost:5432/clinaiqa
DATABASE_URL_SYNC=postgresql+psycopg2://clinaiqa:clinaiqa@localhost:5432/clinaiqa

# Postgres connection details (used by docker-compose)
POSTGRES_USER=clinaiqa
POSTGRES_PASSWORD=clinaiqa
POSTGRES_DB=clinaiqa

# App settings
APP_ENV=development
LOG_LEVEL=INFO
